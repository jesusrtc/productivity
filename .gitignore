# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.coverage

# Content repo (managed as its own git repo, never tracked here)
content/
knowledge/

# Projects (popped out of content/ to the repo root; same untracked model —
# each project folder may hold git worktrees + per-project .agents/memory).
projects/

# Monorepo runtime (state, terminal-pastes, logs — never tracked)
repositories/
.lab/

# Log files
*.log

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# Superpowers scratch
.superpowers/

# html-proposal scratch: tmp/YYYY-MM-DD-<slug>.html files written by
# the html-proposal skill. Local-only working docs, never tracked.
tmp/

core/.venv/
core/.coverage
.lab-server.pid
.lab-server.port
.lab-server.log
.devserver.pid
.playwright-mcp/
.claude/settings.local.json
projects/*/.claude/settings.local.json

# Centralized server + client error logs
logs/

# Trustim skill symlinks — recreated by `lab repo refresh-skills` on
# every `lab repo pull`. They use absolute paths into
# `repositories/trustim-investigation/skills/` so they're machine-
# specific and don't belong in the tree.
.claude/skills/investigation-*
