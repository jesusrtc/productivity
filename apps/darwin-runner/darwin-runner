#!/usr/bin/env python3
"""
DAVI Runner -- Execute DAVI widgets on Darwin via darwin-local-client.

Kernel lifecycle:
  - Default: persistent remote kernel per project, reused across runs.
    Kernel ID stored in .darwin.json next to project.json (kept out of the
    main project doc so productivity's strict model doesn't strip it).
  - --label X: ephemeral kernel, created and destroyed per run (non-blocking).

Project detection walks up for either ``project.json`` (productivity monorepo)
or ``.project.json`` (legacy MP-style). Per-project darwin state lives in a
sibling ``.darwin.json`` with:
  - proxy_user: default proxy user for %set_proxyUser (e.g. "trustim")
  - kernel_id: remote kernel ID for the persistent session

Usage:
    darwin_runner.py setup              Set up darwin-local-client (one-time)
    darwin_runner.py start              Start proxy + connect to Darwin
    darwin_runner.py run <code>         Execute Python code on Darwin
    darwin_runner.py run-local <code>   Execute code locally
    darwin_runner.py stop               Disconnect Darwin + stop proxy
    darwin_runner.py status             Check proxy status

Options for run/run-local:
    --timeout N          Execution timeout in seconds (default: 600)
    --notebook NAME      Save code + output to notebooks/<NAME>.ipynb.
                         When omitted, defaults to the project id from
                         project.json so a single canonical notebook per
                         project accumulates an audit trail.
    --label NAME         Run in an ephemeral kernel (isolated, non-blocking)

All output (except setup) is JSON on stdout. Progress messages go to stderr.
Notebooks are saved to the notebooks/ directory in the project root.
"""

import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

STATE_DIR = Path("/tmp/davi-runner")
DLC_DIR = Path("/tmp/lipy-darwin-local-client")
DLC_VENV = DLC_DIR / ".venv"
DLC_PYTHON = str(DLC_VENV / "bin" / "python")


# ---------------------------------------------------------------------------
# Project config helpers
# ---------------------------------------------------------------------------

def _find_project_dir():
    """Find project root by walking up from cwd.

    Accepts productivity's ``project.json`` or legacy MP ``.project.json``.
    """
    d = Path.cwd()
    while d != d.parent:
        if (d / "project.json").exists() or (d / ".project.json").exists():
            return d
        d = d.parent
    return None


def _project_id():
    """Return the productivity project id from project.json, else None."""
    pdir = _find_project_dir()
    if not pdir:
        return None
    pj = pdir / "project.json"
    if not pj.exists():
        return None
    try:
        return json.loads(pj.read_text()).get("id")
    except (json.JSONDecodeError, OSError):
        return None


def _darwin_state_path():
    """Path to the per-project darwin state file (sibling of project.json)."""
    pdir = _find_project_dir()
    if not pdir:
        return None
    return pdir / ".darwin.json"


def _read_darwin_config():
    """Read the per-project darwin state (.darwin.json)."""
    p = _darwin_state_path()
    if not p or not p.exists():
        return {}
    try:
        return json.loads(p.read_text())
    except (json.JSONDecodeError, OSError):
        return {}


def _write_darwin_config(darwin_cfg):
    """Persist the per-project darwin state (.darwin.json)."""
    p = _darwin_state_path()
    if not p:
        return
    p.write_text(json.dumps(darwin_cfg, indent=2) + "\n")


PROJECT_DIR = _find_project_dir() or Path.cwd()
NOTEBOOKS_DIR = PROJECT_DIR / "notebooks"
ASSETS_DIR = PROJECT_DIR / "assets"

_display_counter = 0


def _save_display(data_type, data):
    """Save a display output to assets/ and return the relative path."""
    global _display_counter
    import base64
    from datetime import datetime

    ASSETS_DIR.mkdir(parents=True, exist_ok=True)
    _display_counter += 1
    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")

    if data_type == "png":
        filename = f"chart-{timestamp}-{_display_counter}.png"
        (ASSETS_DIR / filename).write_bytes(base64.b64decode(data))
    elif data_type == "html":
        filename = f"output-{timestamp}-{_display_counter}.html"
        (ASSETS_DIR / filename).write_text(data, encoding="utf-8")
    else:
        return None

    return f"assets/{filename}"


def _json_out(data):
    print(json.dumps(data, indent=2))


# Threshold above which html/text display output gets replaced with a stub in
# the stdout payload (the calling LLM sees it; the context budget tanks if we
# dump the full Plotly/DAVI HTML which can be multi-megabyte). The notebook
# file keeps the full data either way — truncation happens only on the JSON
# we hand back to the caller.
_STDOUT_DISPLAY_MAX = 4_000


def _truncated_for_stdout(r: dict) -> dict:
    """Return a shallow copy of ``r`` with oversized display/data fields stubbed.

    DAVI's widget setup and Plotly charts each emit single HTML blobs north of
    50KB — and sometimes 3MB — which explode the caller's context if we round-
    trip them verbatim. Replace the payload with a size summary and keep the
    saved-to-``assets/`` path so the caller can still find the rendered copy.
    """
    out = dict(r)
    new_displays = []
    for d in r.get("displays", []) or []:
        d2 = dict(d)
        raw = d.get("data")
        size = len(raw) if isinstance(raw, str) else 0
        if d.get("type") in ("html", "text") and size > _STDOUT_DISPLAY_MAX:
            d2["data"] = raw[:500] + "…"
            d2["truncated"] = True
            d2["size"] = size
        new_displays.append(d2)
    out["displays"] = new_displays

    # stdout streams can also get huge from noisy pod setups (ipython widget
    # bootstrap, pip install output). Cap them too.
    for key in ("stdout", "stderr"):
        v = out.get(key)
        if isinstance(v, str) and len(v) > _STDOUT_DISPLAY_MAX:
            out[key] = v[:_STDOUT_DISPLAY_MAX] + f"\n…[truncated, {len(v)} bytes total]"
    return out


def _ensure_dlc_python():
    """Re-exec with DLC venv Python so jupyter_client and DLC extension are importable."""
    if not Path(DLC_PYTHON).exists():
        _json_out({"success": False, "error": "Run 'lab darwin setup' first"})
        sys.exit(1)
    if os.path.realpath(sys.executable) != os.path.realpath(DLC_PYTHON):
        os.execv(DLC_PYTHON, [DLC_PYTHON, os.path.abspath(__file__)] + sys.argv[1:])


def _build_remote_init(proxy_user):
    """Build the init cell for a remote kernel, using the project's proxy user."""
    return "\n".join([
        "%reload_ext linkedin.lisql",
        "%config SqlMagic.autocommit=False",
        "%manage_trino Holdem",
        f"%set_proxyUser '{proxy_user}'",
        "%matplotlib inline",
        "import matplotlib.pyplot as plt",
        "import pandas as pd",
    ])


# ---------------------------------------------------------------------------
# Kernel execution helper
# ---------------------------------------------------------------------------

def _execute_on_kernel(kc, code, timeout=120):
    """Execute code on a kernel via BlockingKernelClient, return structured output."""
    import queue

    msg_id = kc.execute(code)
    stdout, stderr, displays = [], [], []
    result, error = None, None

    while True:
        try:
            msg = kc.get_iopub_msg(timeout=timeout)
        except queue.Empty:
            if error is None:
                error = f"Timeout after {timeout}s"
            break

        if msg["parent_header"].get("msg_id") != msg_id:
            continue

        mt = msg["msg_type"]
        c = msg["content"]

        if mt == "stream":
            (stdout if c["name"] == "stdout" else stderr).append(c["text"])
        elif mt == "execute_result":
            result = c["data"].get("text/plain")
        elif mt == "display_data":
            data = c.get("data", {})
            if "image/png" in data:
                path = _save_display("png", data["image/png"])
                displays.append({"type": "png", "path": path, "markdown": f"![{path}]({path})"})
            elif "text/html" in data:
                path = _save_display("html", data["text/html"])
                displays.append({"type": "html", "path": path, "data": data["text/html"]})
            elif "text/plain" in data:
                displays.append({"type": "text", "data": data["text/plain"]})
        elif mt == "error":
            error = "\n".join(c.get("traceback", []))
        elif mt == "status" and c["execution_state"] == "idle":
            break

    stderr_text = "".join(stderr)
    # Remote kernel errors from %%remote come through as stderr
    if error is None and "Remote kernel error:" in stderr_text:
        error = stderr_text

    return {
        "success": error is None,
        "stdout": "".join(stdout),
        "stderr": stderr_text,
        "result": result,
        "displays": displays,
        "error": error,
    }


# ---------------------------------------------------------------------------
# Notebook audit trail
# ---------------------------------------------------------------------------

def _append_to_notebook(nb_name, code, output):
    """Append a code cell with outputs to a local .ipynb notebook."""
    import nbformat
    from datetime import datetime

    NOTEBOOKS_DIR.mkdir(parents=True, exist_ok=True)
    nb_path = NOTEBOOKS_DIR / f"{nb_name}.ipynb"

    if nb_path.exists():
        nb = nbformat.read(str(nb_path), as_version=4)
    else:
        nb = nbformat.v4.new_notebook()
        nb.metadata["kernelspec"] = {
            "display_name": "DAVI Runner (Darwin)",
            "language": "python",
            "name": "davi-runner",
        }
        # Add a header cell
        header = nbformat.v4.new_markdown_cell(
            f"# Investigation: {nb_name}\n\n"
            f"Auto-generated audit trail via `davi_runner.py`.\n\n"
            f"Created: {datetime.now().strftime('%Y-%m-%d %H:%M')}"
        )
        nb.cells.append(header)

    # Build notebook outputs from our JSON output
    cell_outputs = []

    if output.get("stdout"):
        cell_outputs.append(nbformat.v4.new_output(
            output_type="stream", name="stdout", text=output["stdout"],
        ))

    if output.get("stderr") and not output.get("error"):
        cell_outputs.append(nbformat.v4.new_output(
            output_type="stream", name="stderr", text=output["stderr"],
        ))

    for d in output.get("displays", []):
        if d["type"] == "html":
            cell_outputs.append(nbformat.v4.new_output(
                output_type="display_data",
                data={"text/html": d.get("data", "")},
                metadata={},
            ))
        elif d["type"] == "png" and d.get("path"):
            # Read saved PNG for notebook embedding
            import base64
            png_path = NOTEBOOKS_DIR.parent / d["path"]
            if png_path.exists():
                b64 = base64.b64encode(png_path.read_bytes()).decode()
                cell_outputs.append(nbformat.v4.new_output(
                    output_type="display_data",
                    data={"image/png": b64},
                    metadata={},
                ))
        elif d["type"] == "text":
            cell_outputs.append(nbformat.v4.new_output(
                output_type="display_data",
                data={"text/plain": d["data"]},
                metadata={},
            ))

    if output.get("result"):
        cell_outputs.append(nbformat.v4.new_output(
            output_type="execute_result",
            data={"text/plain": output["result"]},
            metadata={},
            execution_count=len([c for c in nb.cells if c.cell_type == "code"]) + 1,
        ))

    if output.get("error"):
        cell_outputs.append(nbformat.v4.new_output(
            output_type="error",
            ename="Error",
            evalue=output["error"][:200],
            traceback=output["error"].split("\n"),
        ))

    # Add timestamp as a comment at the top of the cell
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    cell_source = f"# [{timestamp}]\n{code}"

    cell = nbformat.v4.new_code_cell(source=cell_source)
    cell.outputs = cell_outputs
    nb.cells.append(cell)

    nbformat.write(nb, str(nb_path))
    return str(nb_path)


# ---------------------------------------------------------------------------
# PID helpers
# ---------------------------------------------------------------------------

def _save_pid(name, pid):
    (STATE_DIR / f"{name}.pid").write_text(str(pid))


def _is_alive(name):
    pf = STATE_DIR / f"{name}.pid"
    if not pf.exists():
        return False
    try:
        os.kill(int(pf.read_text().strip()), 0)
        return True
    except (ProcessLookupError, ValueError, PermissionError):
        return False


def _kill(name):
    pf = STATE_DIR / f"{name}.pid"
    if pf.exists():
        try:
            os.kill(int(pf.read_text().strip()), signal.SIGTERM)
        except (ProcessLookupError, ValueError):
            pass
        pf.unlink(missing_ok=True)


# ---------------------------------------------------------------------------
# Local kernel helpers
# ---------------------------------------------------------------------------

def _start_local_kernel():
    """Start a local ipykernel, load DLC extension, return (kc, conn_file, pid, error)."""
    import jupyter_client
    from jupyter_client.connect import ConnectionFileMixin

    conn_file = STATE_DIR / f"kernel-{os.getpid()}-connection.json"

    cfm = ConnectionFileMixin()
    cfm.connection_file = str(conn_file)
    cfm.write_connection_file()
    cfm.connection_file = ""

    kernel_proc = subprocess.Popen(
        [DLC_PYTHON, "-m", "ipykernel_launcher", "-f", str(conn_file)],
        stdout=open(STATE_DIR / "kernel.log", "w"),
        stderr=subprocess.STDOUT,
        cwd=str(DLC_DIR),
        start_new_session=True,
    )
    time.sleep(2)

    if kernel_proc.poll() is not None:
        log = (STATE_DIR / "kernel.log").read_text()
        conn_file.unlink(missing_ok=True)
        return None, None, None, f"Kernel exited immediately. Log:\n{log}"

    kc = jupyter_client.BlockingKernelClient()
    kc.load_connection_file(str(conn_file))
    kc.start_channels()
    kc.wait_for_ready(timeout=30)

    # Load DLC extension so %%remote works
    r = _execute_on_kernel(kc, "%load_ext linkedin.darwinlocalclient.kernel_magic")
    if not r["success"]:
        kc.stop_channels()
        _kill_pid(kernel_proc.pid)
        conn_file.unlink(missing_ok=True)
        return None, None, None, f"Failed to load extension: {r['error']}"

    return kc, conn_file, kernel_proc.pid, None


def _stop_local_kernel(kc, conn_file, pid):
    """Tear down a local kernel."""
    if kc:
        try:
            kc.stop_channels()
        except Exception:
            pass
    if pid:
        _kill_pid(pid)
    if conn_file:
        Path(conn_file).unlink(missing_ok=True)


def _kill_pid(pid):
    """Kill a process by PID."""
    try:
        os.kill(pid, signal.SIGTERM)
    except (ProcessLookupError, ValueError, PermissionError):
        pass


# ---------------------------------------------------------------------------
# Remote kernel helpers
# ---------------------------------------------------------------------------

def _check_remote_kernel_alive(kc, kernel_id):
    """Check if a remote kernel ID is still alive on the pod."""
    r = _execute_on_kernel(kc, "%remote --list-kernels", timeout=15)
    return kernel_id in r.get("stdout", "")


def _connect_remote(kc, kernel_id=None):
    """Connect to a specific remote kernel or create a new one.

    Returns (kernel_id, error). Parses kernel ID from stdout.
    """
    if kernel_id:
        r = _execute_on_kernel(kc, f"%remote --connect --kernel-id {kernel_id}", timeout=60)
    else:
        r = _execute_on_kernel(kc, "%remote --connect --new", timeout=180)

    if not r["success"]:
        return None, r.get("error", "Connection failed")

    # Parse kernel ID from stdout like "Connected to ... (kernel: <id>)"
    # or "Created new kernel: <id>"
    import re
    stdout = r.get("stdout", "")
    m = re.search(r'kernel[:\s]+([0-9a-f-]{36})', stdout)
    kid = m.group(1) if m else None
    return kid, None


def _init_remote(kc, proxy_user):
    """Run init cell on the remote kernel."""
    init = _build_remote_init(proxy_user)
    r = _execute_on_kernel(kc, f"%%remote\n{init}", timeout=30)
    if not r["success"]:
        print(f"Warning: init cell failed: {r.get('error', 'unknown')}", file=sys.stderr)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def _python_version_tuple(exe: str):
    """Return (major, minor) for ``exe`` or None if the interpreter won't run."""
    try:
        out = subprocess.run(
            [exe, "-c", "import sys; print(sys.version_info[0], sys.version_info[1])"],
            capture_output=True, text=True, timeout=5,
        )
        if out.returncode != 0:
            return None
        parts = out.stdout.strip().split()
        return (int(parts[0]), int(parts[1]))
    except (OSError, ValueError, subprocess.TimeoutExpired):
        return None


def _find_python():
    """Find a Python >=3.10 for the DLC venv.

    Order:
      1. Versioned names on PATH (python3.13..3.10).
      2. Unversioned ``python3`` on PATH if its actual version is >=3.10.
      3. Common explicit install locations (brew cellars, miniconda envs).
    """
    candidates: list[str] = []

    # 1) versioned names via $PATH
    for name in ["python3.13", "python3.12", "python3.11", "python3.10"]:
        r = subprocess.run(["which", name], capture_output=True, text=True)
        if r.returncode == 0:
            candidates.append(r.stdout.strip())

    # 2) generic python3 — valuable on macOS where brew-installed 3.12 ships
    # only as /opt/homebrew/bin/python3 (no /opt/homebrew/bin/python3.12
    # symlink), or when the user's preferred interpreter lives inside a
    # conda env and is linked into ~/.local/bin.
    for name in ("python3", "python"):
        r = subprocess.run(["which", name], capture_output=True, text=True)
        if r.returncode == 0:
            candidates.append(r.stdout.strip())

    # 3) common explicit locations (brew cellars + productivity's conda env)
    explicit = [
        "/opt/homebrew/bin/python3.13", "/opt/homebrew/bin/python3.12",
        "/opt/homebrew/bin/python3.11", "/opt/homebrew/bin/python3.10",
        "/opt/homebrew/bin/python3",
        "/usr/local/bin/python3.13", "/usr/local/bin/python3.12",
        "/usr/local/bin/python3.11", "/usr/local/bin/python3.10",
        "/opt/homebrew/Caskroom/miniconda/base/envs/productivity/bin/python3.12",
        "/opt/homebrew/Caskroom/miniconda/base/envs/productivity/bin/python3",
    ]
    for p in explicit:
        if os.path.exists(p):
            candidates.append(p)

    # Dedupe while preserving order, then version-check.
    seen: set[str] = set()
    for c in candidates:
        resolved = os.path.realpath(c)
        if resolved in seen:
            continue
        seen.add(resolved)
        v = _python_version_tuple(c)
        if v is not None and v >= (3, 10):
            return c
    return None


# Dependencies from pyproject.toml (avoids needing lipy-hatch-version build plugin)
DLC_DEPS = [
    "aiohttp>=3.9.0", "requests>=2.32.0", "urllib3>=2.6.0",
    "websocket-client>=1.9.0", "ipython>=8.0.0", "ipykernel>=6.0.0",
    "jupyter_client>=8.0.0", "nbformat>=5.0.0",
]


def cmd_setup():
    """Clone darwin-local-client, create venv, install deps. Runs with system Python."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)

    if not DLC_DIR.exists():
        print("Cloning lipy-darwin-local-client...", file=sys.stderr)
        subprocess.run(
            ["git", "clone", "git@github.com:linkedin-multiproduct/lipy-darwin-local-client.git", str(DLC_DIR)],
            check=True,
        )

    py = _find_python()
    if py is None:
        _json_out({"success": False, "error": (
            "Python >=3.10 not found on PATH or in common locations. "
            "Install one of: `brew install python@3.12`, a pyenv version, "
            "or link an existing interpreter into ~/.local/bin/python3.12 "
            "(e.g. `ln -s /opt/homebrew/Caskroom/miniconda/base/envs/productivity/bin/python3.12 "
            "~/.local/bin/python3.12`)."
        )})
        return

    if not DLC_VENV.exists():
        print(f"Creating venv with {py}...", file=sys.stderr)
        subprocess.run([py, "-m", "venv", str(DLC_VENV)], check=True)

    print("Upgrading pip...", file=sys.stderr)
    subprocess.run([DLC_PYTHON, "-m", "pip", "install", "-q", "--upgrade", "pip"], check=True)

    # Install deps directly (skips lipy-hatch-version build plugin requirement)
    print("Installing dependencies...", file=sys.stderr)
    subprocess.run([DLC_PYTHON, "-m", "pip", "install", "-q"] + DLC_DEPS, check=True)

    # Add DLC source to the venv via .pth file so it's importable
    site_pkgs = subprocess.run(
        [DLC_PYTHON, "-c", "import site; print(site.getsitepackages()[0])"],
        capture_output=True, text=True, check=True,
    ).stdout.strip()
    pth_file = Path(site_pkgs) / "darwin-local-client.pth"
    pth_file.write_text(str(DLC_DIR / "src") + "\n")
    print(f"Linked DLC source via {pth_file}", file=sys.stderr)

    # Register a kernel spec pointing to the DLC venv Python
    print("Registering ipykernel...", file=sys.stderr)
    subprocess.run(
        [DLC_PYTHON, "-m", "ipykernel", "install", "--user",
         "--name=davi-runner", "--display-name=DAVI Runner"],
        check=True,
    )

    _json_out({"success": True, "message": "Setup complete", "python": py})


def cmd_start(force=False):
    """Start proxy and connect to Darwin."""
    _ensure_dlc_python()

    STATE_DIR.mkdir(parents=True, exist_ok=True)

    # Already running?
    if _is_alive("proxy") and not force:
        _json_out({"success": False, "error": "Proxy already running. Use 'start --force' to restart."})
        return

    # Clean up stale/existing proxy
    _kill("proxy")

    # Start proxy (bridges localhost:8889 to Darwin)
    print("Starting jupyter-proxy...", file=sys.stderr)
    proxy = subprocess.Popen(
        [DLC_PYTHON, "-m", "linkedin.darwinlocalclient.client_server_application.jupyter_server"],
        stdout=open(STATE_DIR / "proxy.log", "w"),
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    _save_pid("proxy", proxy.pid)
    time.sleep(3)

    if proxy.poll() is not None:
        log = (STATE_DIR / "proxy.log").read_text()
        _json_out({"success": False, "error": f"Proxy exited immediately. Log:\n{log}"})
        return

    # Spin up a temporary local kernel to establish the Darwin connection
    print("Connecting to Darwin (may take up to 150s for pod startup)...", file=sys.stderr)
    kc, conn_file, pid, err = _start_local_kernel()
    if err:
        _json_out({"success": False, "error": err})
        return

    # Shut down any existing remote kernels to get fresh credentials
    _execute_on_kernel(kc, "%remote --connect", timeout=60)
    _execute_on_kernel(kc, "%remote --shutdown", timeout=15)

    r = _execute_on_kernel(kc, "%remote --connect --new", timeout=180)
    if not r["success"]:
        _stop_local_kernel(kc, conn_file, pid)
        _json_out(r)
        return

    # Install lipy-davi on the Darwin pod
    print("Installing lipy-davi on pod...", file=sys.stderr)
    _execute_on_kernel(kc, "%%remote\n!pip install lipy-davi", timeout=120)

    _stop_local_kernel(kc, conn_file, pid)

    r["message"] = "Connected to Darwin. Proxy is running. Use 'run' to execute code."
    _json_out(r)


def cmd_run(code, local=False, timeout=600, notebook=None, label=None):
    """Execute code on Darwin.

    Default: reuse persistent remote kernel from .project.json (init on first use).
    --label: ephemeral kernel, created and destroyed per run.
    """
    _ensure_dlc_python()

    if not local and not _is_alive("proxy"):
        _json_out({"success": False, "error": "No active proxy. Run 'start' first."})
        return

    darwin_cfg = _read_darwin_config()
    proxy_user = darwin_cfg.get("proxy_user", "trustim")

    # Canonical per-project notebook: if caller didn't pick one, default to
    # the productivity project id so every ``darwin-runner run`` appends to
    # the same notebook for the current project.
    if notebook is None:
        pid_hint = _project_id()
        if pid_hint:
            notebook = pid_hint

    kc, conn_file, pid, err = _start_local_kernel()
    if err:
        _json_out({"success": False, "error": err})
        return

    try:
        if local:
            r = _execute_on_kernel(kc, code, timeout=timeout)
        elif label:
            # Ephemeral: create new remote kernel, run, shut down
            kid, cerr = _connect_remote(kc)
            if cerr:
                _json_out({"success": False, "error": cerr})
                return
            _init_remote(kc, proxy_user)
            r = _execute_on_kernel(kc, f"%%remote\n{code}", timeout=timeout)
            _execute_on_kernel(kc, "%remote --shutdown", timeout=10)
        else:
            # Persistent: reuse project kernel or create one
            stored_kid = darwin_cfg.get("kernel_id")
            reused = False

            if stored_kid:
                # Try connecting to the stored kernel
                kid, cerr = _connect_remote(kc, kernel_id=stored_kid)
                if not cerr:
                    reused = True

            if not reused:
                # Create a new remote kernel and save it
                kid, cerr = _connect_remote(kc)
                if cerr:
                    _json_out({"success": False, "error": cerr})
                    return
                # Save kernel ID to project config
                darwin_cfg["kernel_id"] = kid
                if "proxy_user" not in darwin_cfg:
                    darwin_cfg["proxy_user"] = "trustim"
                _write_darwin_config(darwin_cfg)
                # Init only on first creation
                _init_remote(kc, proxy_user)

            r = _execute_on_kernel(kc, f"%%remote\n{code}", timeout=timeout)

        # Save to notebook audit trail — but only for successful runs.
        # Errors are still returned to the caller (so the LLM can read and
        # correct them) but we don't pollute the rendered notebook with
        # failed attempts; the user only wants the readable audit trail.
        if notebook and not r.get("error"):
            nb_path = _append_to_notebook(notebook, code, r)
            r["notebook"] = nb_path

        _json_out(_truncated_for_stdout(r))
    finally:
        _stop_local_kernel(kc, conn_file, pid)


def cmd_stop():
    """Disconnect from Darwin and stop proxy."""
    # Try graceful Darwin disconnect if DLC venv is available
    if Path(DLC_PYTHON).exists() and _is_alive("proxy"):
        try:
            _ensure_dlc_python()
            kc, conn_file, pid, err = _start_local_kernel()
            if not err:
                _execute_on_kernel(kc, "%remote --shutdown", timeout=10)
                _stop_local_kernel(kc, conn_file, pid)
        except Exception:
            pass

    _kill("proxy")

    # Clear stored kernel_id since the pod session is gone
    darwin_cfg = _read_darwin_config()
    if "kernel_id" in darwin_cfg:
        del darwin_cfg["kernel_id"]
        _write_darwin_config(darwin_cfg)

    _json_out({"success": True, "message": "Session stopped"})


def cmd_status():
    """Check if proxy is alive. Show project darwin config."""
    proxy = _is_alive("proxy")
    darwin_cfg = _read_darwin_config()
    _json_out({
        "proxy_alive": proxy,
        "ready": proxy,
        "kernel_id": darwin_cfg.get("kernel_id"),
        "proxy_user": darwin_cfg.get("proxy_user"),
    })


