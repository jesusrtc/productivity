  "description": "Skills and tools for Trust/Safety IR investigation during oncall, leveraging Trino queries and im_playbooks",
  "build": {
    "commands": {
      "build": "./gradlew -Prelease=true -PallArtifacts build coverageByOwner",
      "pre-release": "./gradlew -Prelease=true generateArtifactSpec --no-configuration-cache",
      "precommit": "./gradlew flake8 coverageByOwner",
      "snapshot": "./gradlew -Psnapshot=true build",
      "test": "echo 'testing done by build command'"
    },
    "toolchains": {
      "gradle": {
        "plugins": {
          "ligradle-core": {
            "libraries": [
              "ligradle-core"
            ],
            "version": "7.9.11"
          },
          "ligradle-python": {
            "libraries": [
              "ligradle-python"
            ],
            "version": "4.3.12"
          }
        }
      }
    },
    "type": "gradle",
    "versions": {
      "java": "17.0.5-msft"
    }
  },
  "runtime": {},
  "review": {},
  "topology": {
    "applications": {}
  },
  "archive": {
    "artifacts": {},
    "databases": {},
    "images": {},
    "repo_name": "pypi-internal"
  },
  "dependencyResolution": {},
  "external": {},
  "product": {},
  "trunkDev": {
    "autoRevert": false,
    "enableAutomatedDependencyUpgrades": true
  },
  "extSCM": {}
}
