{
  "name": "trustim-ir-cli",
  "group": "com.linkedin.@spec.name@",
  "version": "0.0.*",
  "scmUrl": "ssh://org-127256988@github.com/linkedin-multiproduct/trustim-ir-cli.git",
  "comment": "",
  "description": "CLI tool for InResponse (airp-web) - manage alerts, incidents, comments, and timelines from the terminal",
  "build": {
    "commands": {
      "build": "./gradlew -Prelease=true -PallArtifacts build",
      "pre-release": "./gradlew -Prelease=true generateArtifactSpec --no-configuration-cache",
      "precommit": "./gradlew flake8 pytest",
      "snapshot": "./gradlew -Psnapshot=true build",
      "test": "echo 'testing done by build command'"
    },
    "toolchains": {
      "gradle": {
        "plugins": {
          "ligradle-core": {
            "libraries": [
              "ligradle-core",
              "packaging-cli-platform",
              "jvm-craft-baseline"
            ],
            "version": "7.9.10"
          },
          "ligradle-python": {
            "libraries": [
              "ligradle-python"
            ],
            "version": "4.*"
          }
        }
      }
    },
    "type": "gradle",
    "versions": {
      "java": "17.0.5-msft"
    }
  },
  "runtime": {},
  "review": {},
  "topology": {
    "applications": {}
  },
  "archive": {
    "artifacts": {},
    "databases": {},
    "images": {},
    "repo_name": "pypi-internal",
    "tags": ["cli-tool", "granular-cli"]
  },
  "dependencyResolution": {},
  "external": {
    "beautifulsoup4": "pypi:beautifulsoup4:4.12.3",
    "click": "pypi:click:8.3.1",
    "requests": "pypi:requests:2.32.5",
    "tabulate": "pypi:tabulate:0.9.0",
    "toml": "pypi:toml:0.10.2"
  },
  "product": {
    "lipy-cli": {
      "libraries": [
        "lipy-cli"
      ],
      "version": "23.*"
    }
  },
  "trunkDev": {
    "autoRevert": false
  },
  "extSCM": {},
  "variants": [
    {
      "r_os": "linux",
      "r_os_release": "mariner2",
      "x_arch": "x86_64"
    },
    {
      "r_os": "darwin",
      "x_arch": "arm64"
    }
  ]
}
